# ============================================================================
# Aegis — environment configuration (copy to .env and edit)
# ============================================================================

# --- Branding / public endpoints -------------------------------------------
AEGIS_BRAND=Aegis
# Public URL of the control-plane API + dashboard (what users hit)
CONTROL_PLANE_URL=https://cp.localtest.me
DASHBOARD_URL=https://cp.localtest.me
# Hostname the edge serves the dashboard/API on (host portion of CONTROL_PLANE_URL)
CONTROL_PLANE_HOST=cp.localtest.me
# Authoritative nameservers we tell customers to delegate to.
ASSIGNED_NS1=ns1.aegis.localtest.me
ASSIGNED_NS2=ns2.aegis.localtest.me

# --- Postgres (control-plane source of truth) ------------------------------
POSTGRES_USER=aegis
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=aegis
# Consumed by the Go API (inside compose network the host is "postgres")
DATABASE_URL=postgres://aegis:change-me-postgres@postgres:5432/aegis?sslmode=disable

# --- Redis (sessions / ratelimit / cache / pubsub / challenge) -------------
REDIS_URL=redis://redis:6379/0

# --- PowerDNS authoritative ------------------------------------------------
PDNS_API_URL=http://powerdns:8081
PDNS_API_KEY=change-me-pdns-api-key
# PowerDNS gpgsql backend creds (its own logical DB in the same postgres)
PDNS_DB_HOST=postgres
PDNS_DB_NAME=pdns
PDNS_DB_USER=pdns
PDNS_DB_PASSWORD=change-me-pdns-db

# --- Control-plane API -----------------------------------------------------
CONTROL_PLANE_PORT=8080
# 32+ byte secrets (use: openssl rand -hex 32)
SESSION_SECRET=change-me-session-secret-0000000000000000000000000000
CSRF_SECRET=change-me-csrf-secret-00000000000000000000000000000000
# Seed admin created on first boot
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
# Dev mailer: "log" prints verification links to stdout; "smtp" uses Mailpit
MAILER=log
SMTP_ADDR=mailpit:1025

# --- Edge data plane (Caddy + agent) ---------------------------------------
# Shared bearer token the node-agent uses to pull config (dev single-node).
# Phase 3 replaces this with per-node mTLS issued at enrollment.
AGENT_TOKEN=change-me-agent-token
# Caddy admin API the agent talks to (localhost inside the edge container)
CADDY_ADMIN_URL=http://127.0.0.1:2019
# Public IP/host that proxied DNS records point at (the edge).
# In all-in-one compose this is the published host; for real edges it's the node IP.
EDGE_PUBLIC_IP=127.0.0.1
# TLS issuance for customer domains: "internal" (Caddy local CA, for testing
# without public DNS) or "acme" (Let's Encrypt/ZeroSSL, needs real domains + 80/443)
EDGE_TLS_MODE=internal
ACME_EMAIL=admin@example.com
# Secret used to sign anti-bot clearance cookies (use: openssl rand -hex 32)
CHALLENGE_SECRET=change-me-challenge-secret-000000000000000000000000

# --- Dashboard (Next.js, build/runtime) ------------------------------------
NEXT_PUBLIC_API_URL=https://cp.localtest.me
