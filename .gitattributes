# Aegis targets Linux/Docker — normalize to LF everywhere, including Windows
# checkouts, so shell scripts, Dockerfiles, and configs don't break on CRLF.
* text=auto eol=lf

# Explicit safety for files that MUST remain LF.
*.sh         text eol=lf
*.bash       text eol=lf
*.go         text eol=lf
*.sql        text eol=lf
*.conf       text eol=lf
*.nft        text eol=lf
*.service    text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.css        text eol=lf
*.md         text eol=lf
Dockerfile   text eol=lf
Makefile     text eol=lf
.env.example text eol=lf
.gitignore   text eol=lf
